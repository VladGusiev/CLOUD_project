        <mxCell id="m10" value="[pod1-ip, pod2-ip, pod3-ip]" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1075" y="640" as="sourcePoint" />
            <mxPoint x="325" y="640" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Note: LB updates round-robin pool -->
        <mxCell id="note-lbupdate" value="LB updates round-robin pool&#xa;new pod now receives traffic" style="shape=callout;html=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;perimeter=calloutPerimeter;size=15;position=0.1;direction=east;" vertex="1" parent="1">
          <mxGeometry x="40" y="650" width="240" height="45" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════
             SECTION 3 — Config Update Flow
        ═══════════════════════════════════════════════ -->

        <mxCell id="sec3-header" value="3. Config Update Flow  (live scaler reconfiguration)" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="715" width="1190" height="30" as="geometry" />
        </mxCell>

        <!-- Browser → LB: PATCH config -->
        <mxCell id="m11" value="PATCH /api/scaler-config  {scale_up_threshold: 60}" style="endArrow=block;endFill=1;html=1;fontSize=11;fontStyle=1;" edge="1" parent="1">
