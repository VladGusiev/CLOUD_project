            <mxPoint x="825" y="810" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Note: scaler applies live -->
        <mxCell id="note-liveconfig" value="setattr(config, 'scale_up_threshold', 60)&#xa;no restart required" style="shape=callout;html=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;perimeter=calloutPerimeter;size=15;position=0.1;direction=west;" vertex="1" parent="1">
