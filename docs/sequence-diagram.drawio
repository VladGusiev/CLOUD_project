        <mxCell id="sec1-header" value="1. Normal Request Flow" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="1190" height="30" as="geometry" />
        </mxCell>

        <!-- Browser → LB: request -->
        <mxCell id="m1" value="GET /{sensor}/sensor/reading" style="endArrow=block;endFill=1;html=1;fontSize=11;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="155" as="sourcePoint" />
            <mxPoint x="325" y="155" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- LB → Sensor Pod: proxy to pod (round-robin pick) -->
        <mxCell id="m2" value="GET /sensor/reading  (round-robin pick)" style="endArrow=block;endFill=1;html=1;fontSize=11;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="325" y="195" as="sourcePoint" />
            <mxPoint x="575" y="195" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Sensor Pod → LB: reading response -->
        <mxCell id="m3" value="{type, value, unit}" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="575" y="235" as="sourcePoint" />
            <mxPoint x="325" y="235" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- LB → Browser: final response -->
        <mxCell id="m4" value="200 OK  (X-Served-By: pod-ip)" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="325" y="275" as="sourcePoint" />
            <mxPoint x="100" y="275" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════════════
             SECTION 2 — Auto-Scale Flow
        ═══════════════════════════════════════════════ -->

        <mxCell id="sec2-header" value="2. Auto-Scale Flow  (CPU threshold triggered)" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="315" width="1190" height="30" as="geometry" />
        </mxCell>

        <!-- Scaler → Sensor Pod: scrape metrics -->
        <mxCell id="m5" value="GET /metrics  (every eval_interval=10s)" style="endArrow=block;endFill=1;html=1;fontSize=11;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="825" y="370" as="sourcePoint" />
            <mxPoint x="575" y="370" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Sensor Pod → Scaler: metrics response -->
        <mxCell id="m6" value="app_cpu_percent=85%" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="575" y="405" as="sourcePoint" />
            <mxPoint x="825" y="405" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Note: scaler decision -->
        <mxCell id="note-decision" value="window avg (83%) &gt; scale_up_threshold (70%)&#xa;cooldown check passes → scale up" style="shape=callout;html=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;perimeter=calloutPerimeter;size=15;position=0.1;direction=west;" vertex="1" parent="1">
          <mxGeometry x="845" y="420" width="260" height="50" as="geometry" />
        </mxCell>

        <!-- Scaler → K8s API: patch scale -->
        <mxCell id="m7" value="PATCH .../deployments/{name}/scale  {replicas: 3}" style="endArrow=block;endFill=1;html=1;fontSize=11;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="825" y="495" as="sourcePoint" />
            <mxPoint x="1075" y="495" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- K8s API → Scaler: 200 OK -->
        <mxCell id="m8" value="200 OK" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1075" y="530" as="sourcePoint" />
            <mxPoint x="825" y="530" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Note: K8s creates new pod -->
        <mxCell id="note-newpod" value="K8s schedules and starts new pod" style="shape=note;html=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="960" y="548" width="230" height="35" as="geometry" />
        </mxCell>

        <!-- LB → K8s API: list pods (pod_sync thread) -->
